# Copy this file to .env and fill in your real values.
# .env is already ignored by git.

# Database connection settings
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_NAME=your_database
DB_PORT=5432

LINZ_API_KEY=your_linz_api_key_here

# Dev-only quick login buttons on /login page
# true  => show quick login buttons
# false => hide quick login buttons (recommended for PA/production)
ENABLE_QUICK_LOGIN=true

# Microsoft Azure AI Foundry — AI assistant integration
# AZURE_AI_AGENT_ENDPOINT: base URL of your Foundry project's agents API
#   e.g. https://your-project.services.ai.azure.com/agents/v1.0
# AZURE_AI_AGENT_KEY:      API key from Foundry project settings
# AZURE_AI_AGENT_ID:       agent (assistant) ID from Foundry
# Leave all three blank to disable the chat widget.
AZURE_AI_AGENT_ENDPOINT=
AZURE_AI_AGENT_KEY=
AZURE_AI_AGENT_ID=

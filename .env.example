# Copy this file to .env and fill in your real values.
# .env is already ignored by git.

# Database connection settings
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_NAME=your_database
DB_PORT=5432
# Set to 'require' for hosted Postgres providers (Neon, Supabase, etc.).
# Leave blank for local PostgreSQL.
DB_SSLMODE=

LINZ_API_KEY=your_linz_api_key_here

# Dev-only quick login buttons on /login page
# true  => show quick login buttons
# false => hide quick login buttons (recommended for PA/production)
ENABLE_QUICK_LOGIN=true

# Cloudflare R2 — durable storage for user uploads (avatars, group photos,
# update photos, ticket screenshots). Leave all five blank for local dev:
# uploads then go to static/ on disk, exactly as before.
# R2_PUBLIC_BASE_URL: the bucket's public URL (r2.dev subdomain or a custom
#   domain), no trailing slash — e.g. https://pub-xxxxxxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Microsoft Azure AI Foundry — AI assistant integration
# AZURE_AI_AGENT_ENDPOINT: base URL of your Foundry project's agents API
#   e.g. https://your-project.services.ai.azure.com/agents/v1.0
# AZURE_AI_AGENT_KEY:      API key from Foundry project settings
# AZURE_AI_AGENT_ID:       agent (assistant) ID from Foundry
# Leave all three blank to disable the chat widget.
AZURE_AI_AGENT_ENDPOINT=
AZURE_AI_AGENT_KEY=
AZURE_AI_AGENT_ID=
